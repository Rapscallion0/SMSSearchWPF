<UserControl x:Class="SMS_Search.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SMS_Search.Views"
             xmlns:vm="clr-namespace:SMS_Search.ViewModels"
             xmlns:conv="clr-namespace:SMS_Search.Converters"
             xmlns:controls="clr-namespace:SMS_Search.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToHiddenConverter x:Key="BoolToHidden"/>
        <conv:HighlightConverter x:Key="HighlightConverter"/>

        <ContextMenu x:Key="HeaderContextMenu">
            <MenuItem Header="{Binding PlacementTarget.Tag.DataContext.HeaderToggleText, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Command="{Binding PlacementTarget.Tag.DataContext.ToggleHeaderDescriptionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      IsEnabled="{Binding PlacementTarget.Tag.DataContext.IsHeaderToggleEnabled, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.Column.SortMemberPath, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <MenuItem Header="Copy Name"
                      Command="{Binding PlacementTarget.Tag.CopyColumnNameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.Column, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <MenuItem Header="Hide Column"
                      Command="{Binding PlacementTarget.Tag.HideColumnCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.Column, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <MenuItem Header="Show Hidden Columns"
                      Visibility="{Binding PlacementTarget.Tag.HasHiddenColumns, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}"
                      ItemsSource="{Binding PlacementTarget.Tag.HiddenColumns, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Header}" />
                        <Setter Property="Command" Value="{Binding PlacementTarget.Tag.ShowColumnCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <Setter Property="CommandParameter" Value="{Binding}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsShowAll}" Value="True">
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Command" Value="{Binding PlacementTarget.Tag.ShowAllColumnsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
            <MenuItem Header="Best Fit"
                      Command="{Binding PlacementTarget.Tag.BestFitCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.Column, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
        </ContextMenu>

        <ContextMenu x:Key="RowContextMenu">
            <MenuItem Header="Copy Row"
                      Command="{Binding PlacementTarget.Tag.DataContext.CopyRowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <MenuItem Header="Copy as SQL INSERT"
                      Command="{Binding PlacementTarget.Tag.DataContext.CopyInsertCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <Separator/>
            <MenuItem Header="Export Selected Rows">
                <MenuItem Header="CSV" Command="{Binding PlacementTarget.Tag.DataContext.ExportSelectedCsvCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                <MenuItem Header="JSON" Command="{Binding PlacementTarget.Tag.DataContext.ExportSelectedJsonCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                <MenuItem Header="XML" Command="{Binding PlacementTarget.Tag.DataContext.ExportSelectedXmlCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            </MenuItem>
        </ContextMenu>

        <ContextMenu x:Key="CellContextMenu">
            <MenuItem Header="Filter by Selection"
                      Command="{Binding PlacementTarget.Tag.FilterBySelectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <MenuItem Header="Copy with Headers"
                      Command="{Binding PlacementTarget.Tag.CopyWithHeadersCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <MenuItem Header="Advanced Copy"
                      Command="{Binding PlacementTarget.Tag.AdvancedCopyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            <MenuItem Header="Copy all matches"
                      Command="{Binding PlacementTarget.Tag.DataContext.CopyAllMatchesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Visibility="{Binding PlacementTarget.Tag.DataContext.CopyAllMatchesCommand.CanExecute, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}"/>
            <Separator/>
            <MenuItem Header="Export Results (All)">
                <MenuItem Header="CSV" Command="{Binding PlacementTarget.Tag.DataContext.ExportCsvCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                <MenuItem Header="JSON" Command="{Binding PlacementTarget.Tag.DataContext.ExportJsonCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                <MenuItem Header="XML" Command="{Binding PlacementTarget.Tag.DataContext.ExportXmlCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="5">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="10,0">
                <Button Content="Previous" Command="{Binding FindPreviousCommand}" Margin="0,0,5,0" Padding="5,2" Visibility="{Binding IsFilterNavigationVisible, Converter={StaticResource BoolToVis}}"/>
                <Button Content="Next" Command="{Binding FindNextCommand}" Padding="5,2" Visibility="{Binding IsFilterNavigationVisible, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,5,0" Visibility="{Binding IsFilterVisible, Converter={StaticResource BoolToHidden}}"/>
            <controls:ClearableTextBox x:Name="txtFilter" Width="200" Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="txtFilter_TextChanged" ToolTip="Filter results (Ctrl+F)" Visibility="{Binding IsFilterVisible, Converter={StaticResource BoolToHidden}}"/>
            <TextBlock Text="{Binding MatchStatusText}" VerticalAlignment="Center" Margin="10,0,0,0" FontStyle="Italic" Foreground="Gray" Visibility="{Binding IsFilterVisible, Converter={StaticResource BoolToHidden}}"/>
        </DockPanel>

        <DataGrid x:Name="resultsGrid" Grid.Row="1" 
                  ItemsSource="{Binding SearchResults}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="{Binding HeadersVisibility}"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="#F8F8F8"
                  FrozenColumnCount="0"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  VirtualizingStackPanel.ScrollUnit="Pixel"
                  VirtualizingStackPanel.CacheLength="10,10"
                  VirtualizingStackPanel.CacheLengthUnit="Item"
                  SelectionChanged="resultsGrid_SelectionChanged"
                  CurrentCellChanged="resultsGrid_CurrentCellChanged" Sorting="resultsGrid_Sorting"
                  LoadingRow="resultsGrid_LoadingRow"
                  PreviewMouseWheel="resultsGrid_PreviewMouseWheel">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource AncestorType=local:ResultsView}}"/>
                    <Setter Property="ContextMenu" Value="{StaticResource HeaderContextMenu}"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                    <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource AncestorType=local:ResultsView}}"/>
                    <Setter Property="ContextMenu" Value="{StaticResource CellContextMenu}"/>
                    <Setter Property="Background">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource HighlightConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="Content"/>
                                <Binding Path="DataContext.FilterText" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                <Binding Path="DataContext.IsHighlightEnabled" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                <Binding Path="DataContext.HighlightColor" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                <Binding RelativeSource="{RelativeSource Self}" Path="Column" />
                                <Binding Path="." />
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                             <Setter Property="Foreground" Value="Black" />
                             <Setter Property="Background" Value="#CCE8FF" />
                             <Setter Property="BorderBrush" Value="#99D1FF" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

        </DataGrid>

        <StatusBar Grid.Row="2">
             <StatusBarItem DockPanel.Dock="Right" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                 <Button Content="Cancel" Command="{Binding CancelCommand}" Margin="5,0,0,0" Padding="10,0" Height="20"/>
             </StatusBarItem>
             <StatusBarItem DockPanel.Dock="Right" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <ProgressBar Width="120" Height="12" IsIndeterminate="True" Margin="5,0"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
