<UserControl x:Class="SMS_Search.Views.Settings.CleanSqlSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ctrl="clr-namespace:SMS_Search.Views.Controls"
             xmlns:vm="clr-namespace:SMS_Search.ViewModels.Settings"
             xmlns:conv="clr-namespace:SMS_Search.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CleanSqlSectionViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:IgnoreNewItemPlaceholderConverter x:Key="IgnoreNewItemPlaceholderConverter" />
        <conv:RawStringConverter x:Key="RawStringConverter" />
        <conv:IsPlaceholderConverter x:Key="IsPlaceholderConverter" />

        <Style x:Key="RowHeaderStyle" TargetType="DataGridRowHeader">
             <Setter Property="Width" Value="25"/>
             <Setter Property="Template">
                  <Setter.Value>
                       <ControlTemplate TargetType="DataGridRowHeader">
                            <Grid Background="Transparent">
                                 <Control x:Name="IconControl"
                                        Template="{x:Null}"
                                        Width="12" Height="12"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="Collapsed"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                 <DataTrigger Binding="{Binding IsEditing, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                      <Setter TargetName="IconControl" Property="Visibility" Value="Visible"/>
                                      <Setter TargetName="IconControl" Property="Template" Value="{StaticResource Icon_Edit}"/>
                                 </DataTrigger>
                                 <MultiDataTrigger>
                                      <MultiDataTrigger.Conditions>
                                           <Condition Binding="{Binding IsEditing, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="False"/>
                                           <Condition Binding="{Binding Item, RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IsPlaceholderConverter}}" Value="True"/>
                                      </MultiDataTrigger.Conditions>
                                      <Setter TargetName="IconControl" Property="Visibility" Value="Visible"/>
                                      <Setter TargetName="IconControl" Property="Template" Value="{StaticResource Icon_NewItem}"/>
                                 </MultiDataTrigger>
                            </ControlTemplate.Triggers>
                       </ControlTemplate>
                  </Setter.Value>
             </Setter>
        </Style>

        <Style x:Key="ContentCellStyle" TargetType="DataGridCell">
             <Setter Property="BorderThickness" Value="0,0,0,1"/>
             <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
        </Style>

        <Style x:Key="TransparentCellStyle" TargetType="DataGridCell">
             <Setter Property="Background" Value="Transparent"/>
             <Setter Property="BorderThickness" Value="0"/>
             <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="TransparentHeaderStyle" TargetType="DataGridColumnHeader">
             <Setter Property="Template">
                  <Setter.Value>
                       <ControlTemplate TargetType="DataGridColumnHeader">
                            <Grid Background="Transparent"/>
                       </ControlTemplate>
                  </Setter.Value>
             </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <GroupBox Header="SQL Formatting Options" Margin="0,0,0,20">
            <StackPanel Margin="5">
                <ctrl:SettingControl Header="Beautify SQL" IsSaved="{Binding BeautifySql.IsSaved}">
                    <CheckBox Content="Automatically format and beautify SQL queries after cleaning" IsChecked="{Binding BeautifySql.Value}" />
                </ctrl:SettingControl>

                <StackPanel Visibility="{Binding BeautifySql.Value, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ctrl:SettingControl Header="Indent Spaces" IsSaved="{Binding IndentStringSpaces.IsSaved}">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding IndentStringSpaces.Value, UpdateSourceTrigger=LostFocus}" Width="60" VerticalContentAlignment="Center" />
                            <TextBlock Text="Number of spaces to use for indentation" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                        </StackPanel>
                    </ctrl:SettingControl>

                    <ctrl:SettingControl Header="Expand Comma Lists" IsSaved="{Binding ExpandCommaLists.IsSaved}">
                        <CheckBox Content="Place comma-separated items on new lines" IsChecked="{Binding ExpandCommaLists.Value}" />
                    </ctrl:SettingControl>

                    <ctrl:SettingControl Header="Expand Boolean Expressions" IsSaved="{Binding ExpandBooleanExpressions.IsSaved}">
                        <CheckBox Content="Place boolean expressions (AND/OR) on new lines" IsChecked="{Binding ExpandBooleanExpressions.Value}" />
                    </ctrl:SettingControl>

                    <ctrl:SettingControl Header="Expand CASE Expressions" IsSaved="{Binding ExpandCaseExpressions.IsSaved}">
                        <CheckBox Content="Place WHEN/THEN clauses in CASE statements on new lines" IsChecked="{Binding ExpandCaseExpressions.Value}" />
                    </ctrl:SettingControl>

                    <ctrl:SettingControl Header="Expand BETWEEN Conditions" IsSaved="{Binding ExpandBetweenConditions.IsSaved}">
                        <CheckBox Content="Place AND clauses in BETWEEN conditions on new lines" IsChecked="{Binding ExpandBetweenConditions.Value}" />
                    </ctrl:SettingControl>

                    <ctrl:SettingControl Header="Break Join ON Sections" IsSaved="{Binding BreakJoinOnSections.IsSaved}">
                        <CheckBox Content="Place ON conditions for JOINs on new lines" IsChecked="{Binding BreakJoinOnSections.Value}" />
                    </ctrl:SettingControl>

                    <ctrl:SettingControl Header="Uppercase Keywords" IsSaved="{Binding UppercaseKeywords.IsSaved}">
                        <CheckBox Content="Convert SQL keywords to uppercase" IsChecked="{Binding UppercaseKeywords.Value}" />
                    </ctrl:SettingControl>

                    <ctrl:SettingControl Header="Keyword Standardization" IsSaved="{Binding EnableKeywordStandardization.IsSaved}">
                        <CheckBox Content="Standardize SQL keywords (e.g. converting LEFT JOIN to LEFT OUTER JOIN)" IsChecked="{Binding EnableKeywordStandardization.Value}" />
                    </ctrl:SettingControl>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Text Cleaning Rules" Margin="0,0,0,20">
            <StackPanel Margin="5">
                <DockPanel LastChildFill="False" Margin="0,0,0,10">
                     <StackPanel Orientation="Horizontal" Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}">
                          <TextBlock Text="Saving..." Foreground="Blue" VerticalAlignment="Center" />
                     </StackPanel>
                     <Button DockPanel.Dock="Right" Content="Restore Defaults" Command="{Binding RestoreDefaultsCommand}" Padding="10,5" />
                </DockPanel>

             <DataGrid ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule, Converter={StaticResource IgnoreNewItemPlaceholderConverter}}"
                       AutoGenerateColumns="False"
                       CanUserAddRows="True"
                       CanUserDeleteRows="True"
                       HeadersVisibility="Column"
                       GridLinesVisibility="Horizontal"
                       BorderThickness="1" BorderBrush="#DDDDDD"
                       Background="White"
                       RowHeaderStyle="{StaticResource RowHeaderStyle}"
                       CanUserSortColumns="False"
                       MinHeight="200">

                  <DataGrid.Columns>
                       <!-- Delete Button Column -->
                       <DataGridTemplateColumn Width="30" CanUserResize="False"
                                               CellStyle="{StaticResource TransparentCellStyle}"
                                               HeaderStyle="{StaticResource TransparentHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                 <DataTemplate>
                                      <Button Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"
                                              BorderThickness="0" Background="Transparent" Padding="2" ToolTip="Remove Rule" Cursor="Hand">
                                           <Button.Style>
                                                <Style TargetType="Button">
                                                     <Setter Property="Visibility" Value="Collapsed"/>
                                                     <Style.Triggers>
                                                          <MultiDataTrigger>
                                                               <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True"/>
                                                                    <Condition Binding="{Binding Item, RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IsPlaceholderConverter}}" Value="False"/>
                                                               </MultiDataTrigger.Conditions>
                                                               <Setter Property="Visibility" Value="Visible"/>
                                                          </MultiDataTrigger>
                                                     </Style.Triggers>
                                                </Style>
                                           </Button.Style>
                                           <Control Template="{StaticResource Icon_Delete}"
                                                  Width="12" Height="12"/>
                                      </Button>
                                 </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                       </DataGridTemplateColumn>

                       <DataGridTextColumn Header="Regex Pattern" Binding="{Binding Pattern, Converter={StaticResource RawStringConverter}, UpdateSourceTrigger=LostFocus}" Width="*"
                                           CellStyle="{StaticResource ContentCellStyle}"/>
                       <DataGridTextColumn Header="Replacement" Binding="{Binding Replacement, Converter={StaticResource RawStringConverter}, UpdateSourceTrigger=LostFocus}" Width="*"
                                           CellStyle="{StaticResource ContentCellStyle}"/>

                       <DataGridTemplateColumn Width="Auto" CanUserResize="False"
                                               CellStyle="{StaticResource TransparentCellStyle}"
                                               HeaderStyle="{StaticResource TransparentHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                 <DataTemplate>
                                      <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                                            <StackPanel.Style>
                                                 <Style TargetType="StackPanel">
                                                      <Setter Property="Opacity" Value="0"/>
                                                      <Setter Property="Visibility" Value="Collapsed"/>
                                                      <Style.Triggers>
                                                           <DataTrigger Binding="{Binding IsSaved}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard Name="FadeInRow">
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <BeginStoryboard Name="FadeOutRow">
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5" />
                                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.5">
                                                                                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
                                                                            </ObjectAnimationUsingKeyFrames>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.ExitActions>
                                                           </DataTrigger>
                                                      </Style.Triggers>
                                                 </Style>
                                            </StackPanel.Style>
                                            <Control Template="{StaticResource Icon_Check}" Width="16" Height="16" />
                                            <TextBlock Text="Saved" Foreground="Green" Margin="5,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                                      </StackPanel>
                                 </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                       </DataGridTemplateColumn>
                  </DataGrid.Columns>
             </DataGrid>
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
