<UserControl x:Class="SMS_Search.Views.Settings.CleanSqlSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ctrl="clr-namespace:SMS_Search.Views.Controls"
             xmlns:vm="clr-namespace:SMS_Search.ViewModels.Settings"
             xmlns:conv="clr-namespace:SMS_Search.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CleanSqlSectionViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:IgnoreNewItemPlaceholderConverter x:Key="IgnoreNewItemPlaceholderConverter" />
        <conv:RawStringConverter x:Key="RawStringConverter" />
        <conv:IsPlaceholderConverter x:Key="IsPlaceholderConverter" />

        <Style x:Key="RowHeaderStyle" TargetType="DataGridRowHeader">
             <Setter Property="Width" Value="25"/>
             <Setter Property="Template">
                  <Setter.Value>
                       <ControlTemplate TargetType="DataGridRowHeader">
                            <Grid Background="Transparent">
                                 <Path x:Name="IconPath"
                                       Data=""
                                       Fill="Gray"
                                       Stretch="Uniform"
                                       Width="12" Height="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                 <DataTrigger Binding="{Binding IsEditing, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                      <Setter TargetName="IconPath" Property="Visibility" Value="Visible"/>
                                      <Setter TargetName="IconPath" Property="Data" Value="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"/>
                                      <Setter TargetName="IconPath" Property="Fill" Value="Black"/>
                                 </DataTrigger>
                                 <MultiDataTrigger>
                                      <MultiDataTrigger.Conditions>
                                           <Condition Binding="{Binding IsEditing, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="False"/>
                                           <Condition Binding="{Binding Item, RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IsPlaceholderConverter}}" Value="True"/>
                                      </MultiDataTrigger.Conditions>
                                      <Setter TargetName="IconPath" Property="Visibility" Value="Visible"/>
                                      <Setter TargetName="IconPath" Property="Data" Value="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z"/>
                                      <Setter TargetName="IconPath" Property="Fill" Value="Gold"/>
                                 </MultiDataTrigger>
                            </ControlTemplate.Triggers>
                       </ControlTemplate>
                  </Setter.Value>
             </Setter>
        </Style>

        <Style x:Key="ContentCellStyle" TargetType="DataGridCell">
             <Setter Property="BorderThickness" Value="0,0,0,1"/>
             <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
        </Style>

        <Style x:Key="TransparentCellStyle" TargetType="DataGridCell">
             <Setter Property="Background" Value="Transparent"/>
             <Setter Property="BorderThickness" Value="0"/>
             <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="TransparentHeaderStyle" TargetType="DataGridColumnHeader">
             <Setter Property="Template">
                  <Setter.Value>
                       <ControlTemplate TargetType="DataGridColumnHeader">
                            <Grid Background="Transparent"/>
                       </ControlTemplate>
                  </Setter.Value>
             </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="0,0,0,20">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
             <StackPanel Orientation="Horizontal" Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="10,0,0,0">
                  <TextBlock Text="Saving..." Foreground="Blue" VerticalAlignment="Center" />
             </StackPanel>
        </StackPanel>

        <Button Content="Restore Defaults" Command="{Binding RestoreDefaultsCommand}" Width="120" HorizontalAlignment="Right" Margin="0,0,0,10" />

        <DockPanel LastChildFill="True">
             <DataGrid ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule, Converter={StaticResource IgnoreNewItemPlaceholderConverter}}"
                       AutoGenerateColumns="False"
                       CanUserAddRows="True"
                       CanUserDeleteRows="True"
                       HeadersVisibility="All"
                       GridLinesVisibility="None"
                       BorderThickness="0"
                       Background="Transparent"
                       RowHeaderStyle="{StaticResource RowHeaderStyle}"
                       PreviewMouseWheel="DataGrid_PreviewMouseWheel"
                       RowEditEnding="DataGrid_RowEditEnding">

                  <DataGrid.Columns>
                       <!-- Delete Button Column -->
                       <DataGridTemplateColumn Width="Auto" CanUserResize="False"
                                               CellStyle="{StaticResource TransparentCellStyle}"
                                               HeaderStyle="{StaticResource TransparentHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                 <DataTemplate>
                                      <Button Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"
                                              BorderThickness="0" Background="Transparent" Padding="2" ToolTip="Remove Rule">
                                           <Button.Style>
                                                <Style TargetType="Button">
                                                     <Setter Property="Visibility" Value="Collapsed"/>
                                                     <Style.Triggers>
                                                          <MultiDataTrigger>
                                                               <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True"/>
                                                                    <Condition Binding="{Binding Item, RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource IsPlaceholderConverter}}" Value="False"/>
                                                               </MultiDataTrigger.Conditions>
                                                               <Setter Property="Visibility" Value="Visible"/>
                                                          </MultiDataTrigger>
                                                     </Style.Triggers>
                                                </Style>
                                           </Button.Style>
                                           <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                 Fill="Red" Width="12" Height="12" Stretch="Uniform"/>
                                      </Button>
                                 </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                       </DataGridTemplateColumn>

                       <DataGridTextColumn Header="Regex Pattern" Binding="{Binding Pattern, Converter={StaticResource RawStringConverter}, UpdateSourceTrigger=LostFocus}" Width="*"
                                           CellStyle="{StaticResource ContentCellStyle}"/>
                       <DataGridTextColumn Header="Replacement" Binding="{Binding Replacement, Converter={StaticResource RawStringConverter}, UpdateSourceTrigger=LostFocus}" Width="*"
                                           CellStyle="{StaticResource ContentCellStyle}"/>

                       <DataGridTemplateColumn Width="Auto" CanUserResize="False"
                                               CellStyle="{StaticResource TransparentCellStyle}"
                                               HeaderStyle="{StaticResource TransparentHeaderStyle}">
                            <DataGridTemplateColumn.CellTemplate>
                                 <DataTemplate>
                                      <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                                            <StackPanel.Style>
                                                 <Style TargetType="StackPanel">
                                                      <Setter Property="Opacity" Value="0"/>
                                                      <Setter Property="Visibility" Value="Collapsed"/>
                                                      <Style.Triggers>
                                                           <DataTrigger Binding="{Binding IsSaved}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <DataTrigger.EnterActions>
                                                                    <StopStoryboard BeginStoryboardName="FadeOutRow"/>
                                                                    <BeginStoryboard Name="FadeInRow">
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <StopStoryboard BeginStoryboardName="FadeInRow"/>
                                                                    <BeginStoryboard Name="FadeOutRow">
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5" />
                                                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.5">
                                                                                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
                                                                            </ObjectAnimationUsingKeyFrames>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.ExitActions>
                                                           </DataTrigger>
                                                      </Style.Triggers>
                                                 </Style>
                                            </StackPanel.Style>
                                            <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="Green" Width="16" Height="16" Stretch="Uniform" />
                                            <TextBlock Text="Saved" Foreground="Green" Margin="5,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                                      </StackPanel>
                                 </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                       </DataGridTemplateColumn>
                  </DataGrid.Columns>
             </DataGrid>
        </DockPanel>
    </StackPanel>
</UserControl>
