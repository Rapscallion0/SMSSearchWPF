<UserControl x:Class="SMS_Search.Views.Settings.EditorSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ctrl="clr-namespace:SMS_Search.Views.Controls"
             xmlns:vm="clr-namespace:SMS_Search.ViewModels.Settings"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:EditorSectionViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>

        <GroupBox Header="IntelliSense" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <ctrl:SettingControl Header="Enable IntelliSense" IsSaved="{Binding EnableIntellisense.IsSaved}">
                    <CheckBox IsChecked="{Binding EnableIntellisense.Value}" Content="Enable SQL IntelliSense in Custom SQL editor" />
                </ctrl:SettingControl>

                <ctrl:SettingControl Header="Automatic Trigger" IsSaved="{Binding AutoTriggerIntellisense.IsSaved}">
                    <CheckBox IsChecked="{Binding AutoTriggerIntellisense.Value}"
                              IsEnabled="{Binding EnableIntellisense.Value}"
                              Content="Automatically trigger IntelliSense while typing" />
                </ctrl:SettingControl>

                <TextBlock Text="Enabled Levels:" Margin="0,10,0,5" FontWeight="SemiBold" />

                <!-- Schema (Always On) -->
                <StackPanel Orientation="Horizontal" Margin="20,2,0,2">
                    <CheckBox IsChecked="True" IsEnabled="False" Content="Schema" Width="100"/>
                    <Control Template="{StaticResource Icon_Info}" Width="16" Height="16" Margin="5,0,0,0" ToolTip="Tables and Columns (Always enabled)"/>
                </StackPanel>

                <!-- Standard -->
                <ctrl:SettingControl IsSaved="{Binding StandardIntellisenseEnabled.IsSaved}" Margin="20,2,0,2">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding StandardIntellisenseEnabled.Value}"
                                  IsEnabled="{Binding EnableIntellisense.Value}"
                                  Content="Standard" Width="100"/>
                        <Control Template="{StaticResource Icon_Info}" Width="16" Height="16" Margin="5,0,0,0" ToolTip="Basic SQL Keywords (SELECT, FROM...)"/>
                    </StackPanel>
                </ctrl:SettingControl>

                <!-- Functional -->
                <ctrl:SettingControl IsSaved="{Binding FunctionalIntellisenseEnabled.IsSaved}" Margin="20,2,0,2">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding FunctionalIntellisenseEnabled.Value}"
                                  IsEnabled="{Binding EnableIntellisense.Value}"
                                  Content="Functional" Width="100"/>
                        <Control Template="{StaticResource Icon_Info}" Width="16" Height="16" Margin="5,0,0,0" ToolTip="SQL Functions (SUM, COUNT...)"/>
                    </StackPanel>
                </ctrl:SettingControl>

                <!-- Full -->
                <ctrl:SettingControl IsSaved="{Binding FullIntellisenseEnabled.IsSaved}" Margin="20,2,0,2">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding FullIntellisenseEnabled.Value}"
                                  IsEnabled="{Binding EnableIntellisense.Value}"
                                  Content="Full" Width="100"/>
                        <Control Template="{StaticResource Icon_Info}" Width="16" Height="16" Margin="5,0,0,0" ToolTip="Admin/DCL commands (GRANT, BACKUP...)"/>
                    </StackPanel>
                </ctrl:SettingControl>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Behavior" Margin="0,0,0,10">
             <StackPanel Margin="5">
                 <ctrl:SettingControl Header="Build SQL Action" IsSaved="{Binding SelectCustomSqlOnBuild.IsSaved}">
                    <CheckBox IsChecked="{Binding SelectCustomSqlOnBuild.Value}" Content="Switch to Custom SQL tab when building query" />
                </ctrl:SettingControl>
             </StackPanel>
        </GroupBox>

        <GroupBox Header="Appearance" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <ctrl:SettingControl Header="Font Family" IsSaved="{Binding SqlFontFamily.IsSaved}">
                    <ctrl:ClearableTextBox Text="{Binding SqlFontFamily.Value, UpdateSourceTrigger=PropertyChanged}" />
                </ctrl:SettingControl>

                <ctrl:SettingControl Header="Font Size" IsSaved="{Binding SqlFontSize.IsSaved}">
                    <ctrl:ClearableTextBox Text="{Binding SqlFontSize.Value, UpdateSourceTrigger=PropertyChanged}" />
                </ctrl:SettingControl>
            </StackPanel>
        </GroupBox>

    </StackPanel>
</UserControl>
