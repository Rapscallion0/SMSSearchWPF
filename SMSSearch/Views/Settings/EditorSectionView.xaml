<UserControl x:Class="SMS_Search.Views.Settings.EditorSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ctrl="clr-namespace:SMS_Search.Views.Controls"
             xmlns:vm="clr-namespace:SMS_Search.ViewModels.Settings"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:EditorSectionViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>

        <GroupBox Header="IntelliSense" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <ctrl:SettingControl Header="Enable IntelliSense" IsSaved="{Binding EnableIntellisense.IsSaved}">
                    <CheckBox IsChecked="{Binding EnableIntellisense.Value}" Content="Enable SQL IntelliSense in Custom SQL editor" />
                </ctrl:SettingControl>

                <ctrl:SettingControl Header="Automatic Trigger" IsSaved="{Binding AutoTriggerIntellisense.IsSaved}">
                    <CheckBox IsChecked="{Binding AutoTriggerIntellisense.Value}"
                              IsEnabled="{Binding EnableIntellisense.Value}"
                              Content="Automatically trigger IntelliSense while typing" />
                </ctrl:SettingControl>

                <ctrl:SettingControl Header="Default Level" IsSaved="{Binding DefaultIntellisenseLevel.IsSaved}">
                    <ComboBox ItemsSource="{Binding IntellisenseLevels}"
                              SelectedItem="{Binding DefaultIntellisenseLevel.Value}"
                              IsEnabled="{Binding EnableIntellisense.Value}"
                              Width="200" HorizontalAlignment="Left">
                        <ComboBox.ToolTip>
                            <ToolTip>
                                <TextBlock>
                                    <Run FontWeight="Bold">Schema:</Run> Tables &amp; Columns<LineBreak/>
                                    <Run FontWeight="Bold">Standard:</Run> + Keywords (SELECT, FROM...)<LineBreak/>
                                    <Run FontWeight="Bold">Functional:</Run> + SQL Functions (SUM, COUNT...)<LineBreak/>
                                    <Run FontWeight="Bold">Full:</Run> + Admin/DCL (GRANT, BACKUP...)
                                </TextBlock>
                            </ToolTip>
                        </ComboBox.ToolTip>
                    </ComboBox>
                </ctrl:SettingControl>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Behavior" Margin="0,0,0,10">
             <StackPanel Margin="5">
                 <ctrl:SettingControl Header="Build SQL Action" IsSaved="{Binding SelectCustomSqlOnBuild.IsSaved}">
                    <CheckBox IsChecked="{Binding SelectCustomSqlOnBuild.Value}" Content="Switch to Custom SQL tab when building query" />
                </ctrl:SettingControl>
             </StackPanel>
        </GroupBox>

        <GroupBox Header="Appearance" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <ctrl:SettingControl Header="Font Family" IsSaved="{Binding SqlFontFamily.IsSaved}">
                    <ctrl:ClearableTextBox Text="{Binding SqlFontFamily.Value, UpdateSourceTrigger=PropertyChanged}" />
                </ctrl:SettingControl>

                <ctrl:SettingControl Header="Font Size" IsSaved="{Binding SqlFontSize.IsSaved}">
                    <ctrl:ClearableTextBox Text="{Binding SqlFontSize.Value, UpdateSourceTrigger=PropertyChanged}" />
                </ctrl:SettingControl>
            </StackPanel>
        </GroupBox>

    </StackPanel>
</UserControl>
