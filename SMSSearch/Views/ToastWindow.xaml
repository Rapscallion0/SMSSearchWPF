<Window x:Class="SMS_Search.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toast Notification"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize"
        Opacity="0.95"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        ContextMenuOpening="Window_ContextMenuOpening">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem x:Name="menuCopyMessage" Header="Copy message" Click="CopyMessage_Click" />
            <MenuItem x:Name="menuCopyAllMessages" Header="Copy all messages" Click="CopyAllMessages_Click" />
            <Separator x:Name="menuSeparator" />
            <MenuItem x:Name="menuCloseAllMessages" Header="Close all messages" Click="CloseAllMessages_Click" />
        </ContextMenu>
    </Window.ContextMenu>
    <Border CornerRadius="5" BorderThickness="2" Background="#252526" BorderBrush="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=BorderBrush}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title & Close -->
                <RowDefinition Height="Auto"/> <!-- Message -->
                <RowDefinition Height="Auto"/> <!-- More Detail Button -->
                <RowDefinition Height="Auto"/> <!-- Details -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblTitle" Text="Title" FontWeight="Bold" FontSize="14" Foreground="White" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button x:Name="btnOpenLog" Width="20" Height="20" Margin="0,0,4,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnOpenFile_Click" Visibility="Collapsed" ToolTip="Open Log File">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid Background="Transparent">
                                    <Path Data="M3,2 L9,2 L13,6 L13,14 A1,1 0 0,1 12,15 L3,15 A1,1 0 0,1 2,14 L2,3 A1,1 0 0,1 3,2 Z M8,2 L8,6 L12,6" Stroke="#F1F1F1" StrokeThickness="1.5" Fill="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Stretch="Uniform"/>
                                    <TextBlock Text="LOG" FontSize="7" FontWeight="Bold" Foreground="#F1F1F1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnOpenFile" Width="20" Height="20" Margin="0,0,4,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnOpenFile_Click" Visibility="Collapsed" ToolTip="Open File">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid Background="Transparent">
                                    <Path x:Name="FileIconPath" Data="M3,2 L9,2 L13,6 L13,14 A1,1 0 0,1 12,15 L3,15 A1,1 0 0,1 2,14 L2,3 A1,1 0 0,1 3,2 Z M8,2 L8,6 L12,6" Stroke="#F1F1F1" StrokeThickness="1.5" Fill="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Stretch="Uniform"/>
                                    <!-- Add TextBlock overlay to indicate type -->
                                    <TextBlock x:Name="FileIconText" Text="" FontSize="7" FontWeight="Bold" Foreground="#F1F1F1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnOpenFolder" Width="16" Height="16" Margin="0,0,4,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnOpenFolder_Click" Visibility="Collapsed" ToolTip="Open Folder">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid Background="Transparent">
                                    <Path Data="M2,4 A1,1 0 0,1 3,3 L6.5,3 L8,5 L13,5 A1,1 0 0,1 14,6 L14,12 A1,1 0 0,1 13,13 L3,13 A1,1 0 0,1 2,12 Z" Stroke="#F1F1F1" StrokeThickness="1.5" Fill="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Stretch="Uniform"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Rectangle x:Name="rectSeparator" Width="1" Height="14" Fill="#555555" Margin="0,0,4,0" Visibility="Collapsed"/>

                    <Button x:Name="btnClose" Width="16" Height="16" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnClose_Click" VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid Background="Transparent">
                                    <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="White" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Message -->
            <TextBlock Grid.Row="1" x:Name="lblMessage" Text="Message" FontSize="12" Foreground="#F1F1F1" TextWrapping="Wrap" Margin="0,0,0,5"/>

            <!-- More Detail Link -->
            <Button Grid.Row="2" x:Name="btnMoreDetail" Content="More Detail..." FontSize="11" Foreground="#007ACC" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Click="btnMoreDetail_Click" Visibility="Collapsed" Cursor="Hand" Margin="0,5,0,0">
                 <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Details -->
            <TextBox Grid.Row="3" x:Name="txtDetails" Text="Details..." FontSize="11" Foreground="LightGray" Background="Transparent" BorderThickness="0" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,5,0,0" IsReadOnly="True"/>
        </Grid>
    </Border>
</Window>
