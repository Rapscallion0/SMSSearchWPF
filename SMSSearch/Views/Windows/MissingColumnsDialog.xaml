<Window x:Class="SMS_Search.Views.Windows.MissingColumnsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Missing Columns Warning" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Warning: Column Mismatch" FontSize="18" FontWeight="SemiBold" Foreground="#D32F2F" Margin="0,0,0,10" Grid.Row="0"/>

        <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,15" Grid.Row="1"/>

        <DataGrid x:Name="ColumnsGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" Margin="0,0,0,20" HeadersVisibility="Column" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Column Name" Binding="{Binding ColumnName}" IsReadOnly="True" Width="1.5*"/>
                <DataGridCheckBoxColumn Header="In Template" Binding="{Binding IsInTarget}" IsReadOnly="True" Width="*"/>
                <DataGridCheckBoxColumn Header="In Source" Binding="{Binding IsInSource}" IsReadOnly="True" Width="*"/>

                <DataGridTemplateColumn Header="Import" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding ShouldImport, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding IsMissing}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Data Type" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedValue="{Binding SuggestedDataType, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding ShouldImport}"
                                      IsEditable="True">
                                <ComboBoxItem Content="VARCHAR(MAX)"/>
                                <ComboBoxItem Content="INT"/>
                                <ComboBoxItem Content="FLOAT"/>
                                <ComboBoxItem Content="DATETIME"/>
                                <ComboBoxItem Content="BIT"/>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Cancel Import" Click="Cancel_Click" Grid.Column="0" Padding="5"/>
            <Button Content="Continue" Click="Continue_Click" Grid.Column="2" Padding="5"/>
        </Grid>
    </Grid>
</Window>
