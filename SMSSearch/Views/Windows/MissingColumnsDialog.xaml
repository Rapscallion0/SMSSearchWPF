<Window x:Class="SMS_Search.Views.Windows.MissingColumnsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Missing Columns Warning" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Warning: Column Mismatch" FontSize="18" FontWeight="SemiBold" Foreground="#D32F2F" Margin="0,0,0,10" Grid.Row="0"/>

        <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,15" Grid.Row="1"/>

        <DataGrid x:Name="ColumnsGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" Margin="0,0,0,20" HeadersVisibility="Column" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Column Name" Binding="{Binding ColumnName}" IsReadOnly="True" Width="1.5*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="In Template" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl HorizontalAlignment="Center" VerticalAlignment="Center" Width="16" Height="16">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Template" Value="{StaticResource Icon_Clear}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInTarget}" Value="True">
                                                <Setter Property="Template" Value="{StaticResource Icon_Check}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="In Source" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl HorizontalAlignment="Center" VerticalAlignment="Center" Width="16" Height="16">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Template" Value="{StaticResource Icon_Clear}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInSource}" Value="True">
                                                <Setter Property="Template" Value="{StaticResource Icon_Check}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Import" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding ShouldImport, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding IsMissing}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Data Type" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox Text="{Binding SuggestedDataType, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding ShouldImport}"
                                      IsEditable="True"
                                      VerticalAlignment="Center">
                                <ComboBoxItem Content="int"/>
                                <ComboBoxItem Content="bigint"/>
                                <ComboBoxItem Content="decimal(18,2)"/>
                                <ComboBoxItem Content="float"/>
                                <ComboBoxItem Content="bit"/>
                                <ComboBoxItem Content="varchar(max)"/>
                                <ComboBoxItem Content="nvarchar(255)"/>
                                <ComboBoxItem Content="char(n)"/>
                                <ComboBoxItem Content="date"/>
                                <ComboBoxItem Content="datetime2"/>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Cancel Import" Click="Cancel_Click" Grid.Column="0" Padding="5"/>
            <Button Content="Continue" Click="Continue_Click" Grid.Column="2" Padding="5"/>
        </Grid>
    </Grid>
</Window>
