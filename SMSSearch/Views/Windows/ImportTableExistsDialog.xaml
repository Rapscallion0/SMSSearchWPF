<Window x:Class="SMS_Search.Views.Windows.ImportTableExistsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Table Already Exists" Height="250" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Warning: Table Exists" FontSize="18" FontWeight="SemiBold" Foreground="#D32F2F" Margin="0,0,0,10" Grid.Row="0"/>

        <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,15" Grid.Row="1"/>

        <TextBlock Text="How would you like to proceed?" FontSize="14" Margin="0,0,0,20" Grid.Row="2"/>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Recreate" Click="Recreate_Click" Grid.Column="0" Padding="5"/>
            <Button Content="Recreate All" Click="RecreateAll_Click" Grid.Column="2" Padding="5"/>
            <Button Content="Skip" Click="Skip_Click" Grid.Column="4" Padding="5"/>
            <Button Content="Skip All" Click="SkipAll_Click" Grid.Column="6" Padding="5"/>
        </Grid>
    </Grid>
</Window>
