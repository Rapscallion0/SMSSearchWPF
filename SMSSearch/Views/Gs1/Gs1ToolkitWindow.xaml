<Window x:Class="SMS_Search.Views.Gs1.Gs1ToolkitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SMS_Search.ViewModels.Gs1"
        xmlns:views="clr-namespace:SMS_Search.Views.Gs1"
        mc:Ignorable="d"
        Title="GS1 Barcode Toolkit" Height="600" Width="1000" WindowStartupLocation="CenterOwner" MinWidth="600" MinHeight="400">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Validation Error Template (Empty to suppress default red border, handled via triggers) -->
        <ControlTemplate x:Key="ErrorTemplate">
            <AdornedElementPlaceholder/>
        </ControlTemplate>

        <Style x:Key="ModifiableTextBoxStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ErrorTemplate}"/>
            <Setter Property="ToolTip" Value="Press Enter to apply, Esc to revert, or click away to save"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="Red" BlurRadius="5" ShadowDepth="0" Opacity="0.8"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="ToolTip" Value="{Binding (Validation.Errors)[0].ErrorContent, RelativeSource={x:Static RelativeSource.Self}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModifiableRawBarcodeTextBoxStyle" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <DataTemplate x:Key="ValueTextTemplate">
            <TextBox Text="{Binding DraftValue, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                     Style="{StaticResource ModifiableTextBoxStyle}"
                     BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                     LostFocus="TextBox_LostFocus"
                     PreviewTextInput="TextBox_PreviewTextInput"
                     Loaded="TextBox_Loaded"
                     Unloaded="TextBox_Unloaded">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding CommitCommand}"/>
                    <KeyBinding Key="Escape" Command="{Binding RevertCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
        </DataTemplate>

        <DataTemplate x:Key="ValueReadOnlyTextTemplate">
            <TextBox Text="{Binding DisplayValue, Mode=OneWay}"
                     IsReadOnly="True" Foreground="#555555"
                     BorderThickness="0" Background="#F0F0F0" VerticalContentAlignment="Center" Padding="2,0">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnimatingUpdate}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                             From="0" To="20" Duration="0:0:0.25" AutoReverse="True" RepeatBehavior="2x"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#008000" BlurRadius="0" ShadowDepth="0" Opacity="1.0"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </DataTemplate>

        <DataTemplate x:Key="ValueCheckBoxTemplate">
            <CheckBox IsChecked="{Binding BoolValue, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0"/>
        </DataTemplate>

        <DataTemplate x:Key="ValueComboBoxTemplate">
            <ComboBox ItemsSource="{Binding Options}"
                      SelectedValue="{Binding DraftValue, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Value"
                      DisplayMemberPath="Label"
                      BorderThickness="0" Background="Transparent" Margin="0,0,0,0">
                <ComboBox.Style>
                    <Style TargetType="ComboBox">
                        <Style.Triggers>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Red" BlurRadius="5" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="ToolTip" Value="{Binding (Validation.Errors)[0].ErrorContent, RelativeSource={x:Static RelativeSource.Self}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Style>
            </ComboBox>
        </DataTemplate>

        <views:Gs1ValueTemplateSelector x:Key="ValueTemplateSelector"
                                        TextTemplate="{StaticResource ValueTextTemplate}"
                                        ReadOnlyTextTemplate="{StaticResource ValueReadOnlyTextTemplate}"
                                        CheckBoxTemplate="{StaticResource ValueCheckBoxTemplate}"
                                        ComboBoxTemplate="{StaticResource ValueComboBoxTemplate}"/>
    </Window.Resources>

    <DockPanel>
        <!-- Header / Input -->
        <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Control Width="32" Height="32" Margin="0,0,10,0">
                    <Control.Style>
                        <Style TargetType="Control">
                            <Setter Property="Template" Value="{StaticResource Icon_Gs1_Type_Generic}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DetectedType}" Value="GS1 Databar Coupon">
                                    <Setter Property="Template" Value="{StaticResource Icon_Gs1_Type_Coupon}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DetectedType}" Value="SSCC-18">
                                    <Setter Property="Template" Value="{StaticResource Icon_Gs1_Type_SSCC}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DetectedType}" Value="GTIN-14">
                                    <Setter Property="Template" Value="{StaticResource Icon_Gs1_Type_GTIN}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DetectedType}" Value="GS1-128 (GTIN + Attributes)">
                                    <Setter Property="Template" Value="{StaticResource Icon_Gs1_Type_GTIN}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DetectedType}" Value="GCN">
                                    <Setter Property="Template" Value="{StaticResource Icon_Gs1_Type_GCN}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DetectedType}" Value="GDTI">
                                    <Setter Property="Template" Value="{StaticResource Icon_Gs1_Type_GDTI}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Control.Style>
                </Control>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding DetectedType}" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding DraftRawBarcode, UpdateSourceTrigger=PropertyChanged}"
                                 Height="25" Style="{StaticResource ModifiableRawBarcodeTextBoxStyle}"
                                 ToolTip="Paste GS1 Barcode Data Here (Press Enter to apply, Esc to revert)">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding CommitRawBarcodeCommand}"/>
                                <KeyBinding Key="Escape" Command="{Binding RevertRawBarcodeCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding CommitRawBarcodeCommand}" Content="Decode" Height="25" Margin="5,0,0,0" Padding="10,0"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Template:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding AvailableTemplates}" SelectedItem="{Binding SelectedTemplate}" Width="200" Height="25"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer / Commands -->
        <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding ViewBarcodeCommand}" Content="View Barcode" Width="100"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Breakdown Grid -->
            <DockPanel Grid.Column="0" Margin="10">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding BarcodeSegments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" MouseEnter="Segment_MouseEnter" MouseLeave="Segment_MouseLeave" MouseLeftButtonDown="Segment_MouseLeftButtonDown" ToolTip="{Binding ToolTipText}">
                                            <TextBlock Text="{Binding Text}" FontSize="16" Margin="0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsSelected}" Value="True"/>
                                                                    <Condition Binding="{Binding DataContext.IsAnySegmentHovered, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                <Setter Property="Foreground" Value="Green"/>
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding IsHovered}" Value="True">
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                <Setter Property="Foreground" Value="Green"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsAnimatingUpdate}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                                             From="0" To="20" Duration="0:0:0.25" AutoReverse="True" RepeatBehavior="2x"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#008000" BlurRadius="0" ShadowDepth="0" Opacity="1.0"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Button Grid.Column="1" Command="{Binding CopyCodeCommand}" Width="32" Height="32" Margin="5,0,0,0" ToolTip="Copy Full Barcode">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" CornerRadius="4" x:Name="Bd">
                                        <Path Data="M19 21H8V7H19M19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1Z"
                                              Fill="{TemplateBinding Foreground}" Stretch="Uniform" Margin="6"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#E0E0E0"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding FilteredDefinitions}"
                              SelectedItem="{Binding SelectedDefinitionToAdd}"
                              Width="200" Margin="0,0,5,0"
                              IsEditable="False" IsTextSearchEnabled="True" TextSearch.TextPath="Ai"
                              Visibility="{Binding IsAddAiVisible, Converter={StaticResource BoolToVis}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock ToolTip="{Binding Description}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} - {1}">
                                            <Binding Path="Ai"/>
                                            <Binding Path="Title"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Command="{Binding AddAiCommand}" Content="Add AI" Width="60" Margin="0,0,10,0"
                            Visibility="{Binding IsAddAiVisible, Converter={StaticResource BoolToVis}}"/>
                        <Button Command="{Binding ClearValuesCommand}" Content="Clear Values" Width="80"/>
                    </StackPanel>
                </StackPanel>

                <DataGrid x:Name="AisDataGrid" ItemsSource="{Binding ParsedAis}" SelectedItem="{Binding SelectedAi}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserResizeRows="False" SelectionMode="Single" SelectionUnit="Cell" SelectedCellsChanged="AisDataGrid_SelectedCellsChanged">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHovered}" Value="True">
                                    <Setter Property="Panel.ZIndex" Value="1"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#008000" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Setter Property="Background" Value="#CCE8FF" />
                                    <Setter Property="BorderBrush" Value="#99D1FF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="Auto" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <ToggleButton x:Name="InfoButton" Content="ℹ" Width="20" Height="20" Background="Transparent" BorderThickness="0" Margin="0" ToolTip="AI Information"/>
                                        <Popup IsOpen="{Binding IsChecked, ElementName=InfoButton}" StaysOpen="False" PlacementTarget="{Binding ElementName=InfoButton}" Placement="Bottom" AllowsTransparency="True">
                                            <Border Background="White" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                                                </Border.Effect>
                                                <StackPanel MinWidth="200" MaxWidth="300">
                                                    <TextBlock Text="{Binding Ai, StringFormat='AI: {0}'}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,5">
                                                        <Run Text="Title: " FontWeight="SemiBold"/>
                                                        <Run Text="{Binding Title, Mode=OneWay}"/>
                                                    </TextBlock>

                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}">
                                                        <Run Text="Description: " FontWeight="SemiBold"/>
                                                        <Run Text="{Binding Description, Mode=OneWay}"/>
                                                    </TextBlock>

                                                    <ItemsControl ItemsSource="{Binding Options}" Margin="0,0,0,10">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Options}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                    <TextBlock Text="{Binding Value, StringFormat='{}• {0}: '}" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding Label}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Text="Data Type:" Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Margin="0,0,5,2"/>
                                                        <TextBlock Text="{Binding DataType}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,2"/>

                                                        <TextBlock Text="Length:" Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Margin="0,0,5,2"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,2">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0} - {1}">
                                                                    <Binding Path="MinLength"/>
                                                                    <Binding Path="MaxLength"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>

                                                        <TextBlock Text="Required:" Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Margin="0,0,5,2"/>
                                                        <TextBlock Text="{Binding IsRequired, StringFormat='{}{0}'}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,2"/>

                                                        <TextBlock Text="Read Only:" Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding IsReadOnly, StringFormat='{}{0}'}" Grid.Row="3" Grid.Column="1"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="AI" Binding="{Binding Ai}" IsReadOnly="True" Width="Auto"/>
                        <DataGridTemplateColumn Header="Description" Width="Auto" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBox Text="{Binding Title, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 VerticalContentAlignment="Center"
                                                 IsHitTestVisible="True"
                                                 Focusable="True" />
                                        <TextBlock Text=" *" Foreground="Red" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRequired}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Value" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding}" ContentTemplateSelector="{StaticResource ValueTemplateSelector}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding}" ContentTemplateSelector="{StaticResource ValueTemplateSelector}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Column 2 placeholder when pinned -->
            <Grid Grid.Column="2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Width" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHistoryPanelPinned}" Value="True">
                                <Setter Property="Width" Value="{Binding HistoryPanelWidth, Mode=TwoWay}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
            </Grid>

            <!-- Transparent Overlay to Close Unpinned History Flyout -->
            <Grid Grid.Column="0" Grid.ColumnSpan="3" Panel.ZIndex="9" Background="Transparent" MouseLeftButtonDown="HistoryOverlay_MouseLeftButtonDown">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsHistoryPanelOpen}" Value="True"/>
                                    <Condition Binding="{Binding IsHistoryPanelPinned}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
            </Grid>

            <!-- History Flyout Panel Overlay -->
            <Grid Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Right" Panel.ZIndex="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid.Style>
                    <Style TargetType="Grid">
                        <!-- Default state is the flyout mode. If pinned, it docks to Column 2's width directly -->
                        <Setter Property="Width" Value="Auto"/>
                    </Style>
                </Grid.Style>

                <!-- Resizable Content Area -->
                <Border Grid.Column="1" Background="White" BorderBrush="Gray" BorderThickness="1,0,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Width" Value="{Binding HistoryPanelWidth, Mode=TwoWay}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistoryPanelOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsHistoryPanelPinned}" Value="True"/>
                                        <Condition Binding="{Binding IsHistoryPanelOpen}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <!-- Thumb for resizing -->
                        <Thumb HorizontalAlignment="Left" Width="5" Cursor="SizeWE" Background="Transparent" Panel.ZIndex="2" DragDelta="HistoryPanelThumb_DragDelta">
                            <Thumb.Style>
                                <Style TargetType="Thumb">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </Style>
                            </Thumb.Style>
                        </Thumb>

                        <!-- History Main Content -->
                        <DockPanel Margin="5,10,10,10" MinWidth="200">
                            <!-- Toolbar at the top -->
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Expand/Collapse Toggle -->
                                <Button Grid.Column="0" Command="{Binding ToggleHistoryPanelCommand}" Width="24" Height="24" ToolTip="Collapse History" Background="Transparent" BorderThickness="0" Foreground="#607D8B">
                                    <Control Template="{StaticResource Icon_Chevron_Right}" />
                                </Button>

                                <TextBlock Grid.Column="1" Text="History" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="#607D8B"/>

                                <!-- Pinned Toggle -->
                                <Button Grid.Column="2" Command="{Binding ToggleHistoryPanelPinnedCommand}" Width="24" Height="24" Background="Transparent" BorderThickness="0" Foreground="#607D8B">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="ToolTip" Value="Unpinned" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHistoryPanelPinned}" Value="True">
                                                    <Setter Property="ToolTip" Value="Pinned" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid>
                                        <Control Template="{StaticResource Icon_Pin_Pinned}">
                                            <Control.Style>
                                                <Style TargetType="Control">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHistoryPanelPinned}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Control.Style>
                                        </Control>
                                        <Control Template="{StaticResource Icon_Pin_Unpinned}">
                                            <Control.Style>
                                                <Style TargetType="Control">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHistoryPanelPinned}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Control.Style>
                                        </Control>
                                    </Grid>
                                </Button>
                            </Grid>

                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="2">
                                <ListBox ItemsSource="{Binding History}" BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                            <EventSetter Event="MouseDoubleClick" Handler="HistoryItem_MouseDoubleClick"/>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Load"
                                                  Command="{Binding PlacementTarget.Tag.LoadHistoryItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="Delete"
                                                  Command="{Binding PlacementTarget.Tag.DeleteHistoryItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="Clear All"
                                                  Command="{Binding PlacementTarget.Tag.ClearHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2">
                                <TextBlock Text="{Binding DetectedType}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding FormattedValue}" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                            </Border>
                        </DockPanel>
                    </Grid>
                </Border>

                <!-- Collapsed Narrow Bar -->
                <Border Grid.Column="0" Width="30" Background="#F0F0F0" BorderBrush="Gray" BorderThickness="1,0,0,0" MouseLeftButtonUp="CollapsedHistoryBar_MouseLeftButtonUp" Cursor="Hand" ToolTip="Expand History">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistoryPanelOpen}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <!-- Expand Chevron -->
                        <Control Template="{StaticResource Icon_Chevron_Left}" Width="24" Height="24" Foreground="#607D8B" VerticalAlignment="Top" Margin="0,5,0,0"/>

                        <!-- Sideways Text -->
                        <TextBlock Text="History" FontWeight="SemiBold" Foreground="#607D8B" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
