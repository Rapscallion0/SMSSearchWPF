<Window x:Class="SMS_Search.Views.Gs1.Gs1BarcodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Barcode" Height="400" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <CheckBox IsChecked="{Binding IncludeDetails}" Content="Include details on print/PDF" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <TextBlock Text="Symbology:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding AvailableSymbologies}" SelectedItem="{Binding SelectedSymbology}" Width="120" Margin="0,0,15,0"/>

            <Button Command="{Binding CopySvgCommand}" Content="Copy SVG" Width="80" Margin="0,0,10,0"/>
            <Button Command="{Binding SavePdfCommand}" Content="Save as PDF" Width="100" Margin="0,0,10,0"/>
            <Button Command="{Binding PrintCommand}" Content="Print" Width="80"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Background="White">
            <Image Source="{Binding BarcodeImage}" Stretch="Uniform" Margin="10"/>
        </Border>
    </Grid>
</Window>