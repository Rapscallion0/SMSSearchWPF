<Window x:Class="SMS_Search.Views.Gs1.Gs1BarcodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Barcode" Height="400" Width="750" MinHeight="400" MinWidth="750" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        LocationChanged="Window_LocationChanged" SizeChanged="Window_SizeChanged">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0" IsChecked="{Binding IncludeDetails}" Content="Include details on print/PDF" VerticalAlignment="Center" Margin="0,0,15,0"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Symbology:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding AvailableSymbologies}" SelectedItem="{Binding SelectedSymbology}" Width="120" Margin="0,0,15,0"/>

                <Button Command="{Binding CopySvgCommand}" Content="Copy SVG" Width="80" Margin="0,0,10,0"/>
                <Button Command="{Binding SavePdfCommand}" Content="Save as PDF" Width="100" Margin="0,0,10,0"/>
                <Button Command="{Binding PrintCommand}" Content="Print" Width="80"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Barcode Name (Optional):" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Grid.Column="1" Text="{Binding BarcodeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,15,0"/>

            <TextBlock Grid.Column="2" Text="Description (Optional):" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Grid.Column="3" Text="{Binding BarcodeDescription, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Background="White">
            <Image Source="{Binding BarcodeImage}" Stretch="Uniform" Margin="10"/>
        </Border>
    </Grid>
</Window>