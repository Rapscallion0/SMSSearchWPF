<UserControl x:Class="SMS_Search.Views.Controls.SqlEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <avalon:TextEditor x:Name="Editor"
                           Grid.Row="0"
                           ShowLineNumbers="True"
                           FontFamily="{Binding EditorFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="{Binding EditorFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           WordWrap="True"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Auto"
                           TextChanged="Editor_TextChanged"/>
        <Thumb x:Name="ResizeGrip" Grid.Row="1" Height="10" Cursor="SizeNS" DragDelta="ResizeGrip_DragDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Grid Background="Transparent">
                        <Path Data="M 0 5 L 100 5" Stroke="Gray" StrokeThickness="1" StrokeDashArray="2 2" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="5,0"/>
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</UserControl>
