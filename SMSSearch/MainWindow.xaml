<Window x:Class="SMS_Search.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SMS_Search"
        xmlns:views="clr-namespace:SMS_Search.Views"
        xmlns:controls="clr-namespace:SMS_Search.Views.Controls"
        xmlns:vm="clr-namespace:SMS_Search.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding Title}" Height="800" Width="800"
        Icon="pack://application:,,,/Resources/SMS Search.ico" MinWidth="675" MinHeight="600">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding SearchCommand}" />
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="SearchRow" Height="310" MinHeight="310"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Search Criteria" Margin="10">
            <views:SearchView DataContext="{Binding SearchVm}" Margin="0,5,0,0"/>
        </GroupBox>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" ResizeBehavior="PreviousAndNext"/>

        <views:ResultsView Grid.Row="2" DataContext="{Binding ResultsVm}" Margin="10,0,10,10"/>

        <StatusBar Grid.Row="3" x:Name="MainStatusBar" SizeChanged="MainStatusBar_SizeChanged">
            <StatusBarItem>
                <StackPanel x:Name="LeftStatusPanel" Orientation="Horizontal">
                    <TextBlock x:Name="JulianLabel" Text="Julian:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding JulianDateText, UpdateSourceTrigger=PropertyChanged}" Width="60" MaxLength="7" VerticalContentAlignment="Center"/>
                    <TextBlock x:Name="GregorianLabel" Text="Gregorian:" Margin="10,0,5,0" VerticalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding GregorianDate}" Width="100"/>

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0,10,0"/>

                    <TextBlock x:Name="DatabaseLabel" Text="Database:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="DatabaseComboBox" MinWidth="150" Height="22" VerticalAlignment="Center"
                              ItemsSource="{Binding DatabasesView}" SelectedItem="{Binding SelectedDatabase}"
                              IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                              VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                              PreviewKeyDown="DatabaseComboBox_PreviewKeyDown" KeyUp="DatabaseComboBox_KeyUp" GotFocus="DatabaseComboBox_GotFocus"
                              PreviewMouseDoubleClick="DatabaseComboBox_PreviewMouseDoubleClick" LostFocus="DatabaseComboBox_LostFocus">
                    </ComboBox>

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0,0,0"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right" x:Name="RightStatusItem">
                <StackPanel x:Name="RightStatusPanel" Orientation="Horizontal">
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,10,0"/>

                    <Button Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource TransparentIconButtonStyle}" ToolTip="Settings" Margin="0,0,10,0">
                        <Control Template="{StaticResource Icon_Settings}"
                               Width="16" Height="16"/>
                    </Button>
                    <ToggleButton Command="{Binding OpenImportCommand}" IsChecked="{Binding IsImportTargetVisible, Mode=OneWay}" ToolTip="Import Files"
                                  Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0">
                        <ToggleButton.Style>
                             <Style TargetType="ToggleButton">
                                 <Setter Property="Template">
                                     <Setter.Value>
                                         <ControlTemplate TargetType="ToggleButton">
                                             <Border Background="Transparent">
                                                 <ContentPresenter/>
                                             </Border>
                                         </ControlTemplate>
                                     </Setter.Value>
                                 </Setter>
                             </Style>
                        </ToggleButton.Style>
                        <Control Template="{StaticResource Icon_Import}" Width="16" Height="16"/>
                    </ToggleButton>
                    <ToggleButton Command="{Binding OpenUnarchiveCommand}" IsChecked="{Binding IsUnarchiveTargetVisible, Mode=OneWay}" ToolTip="Unarchive Target"
                                  Background="Transparent" BorderThickness="0" Padding="0">
                        <ToggleButton.Style>
                             <Style TargetType="ToggleButton">
                                 <Setter Property="Template">
                                     <Setter.Value>
                                         <ControlTemplate TargetType="ToggleButton">
                                             <Border Background="Transparent">
                                                 <ContentPresenter/>
                                             </Border>
                                         </ControlTemplate>
                                     </Setter.Value>
                                 </Setter>
                             </Style>
                        </ToggleButton.Style>
                        <Image Source="/Resources/Unarchive.png" Width="16" Height="16"/>
                    </ToggleButton>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid x:Name="MaskOverlay" Background="#AA000000" Visibility="Collapsed" Grid.RowSpan="4"/>

        <controls:ImportOverlay Grid.RowSpan="4" DataContext="{Binding ImportVm}" Visibility="{Binding DataContext.IsImportTargetVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" Panel.ZIndex="10"/>
    </Grid>
</Window>
