<Window x:Class="SMS_Search.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SMS_Search"
        xmlns:views="clr-namespace:SMS_Search.Views"
        xmlns:vm="clr-namespace:SMS_Search.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding Title}" Height="800" Width="800"
        Icon="pack://application:,,,/Resources/SMS Search.ico" MinWidth="675" MinHeight="600">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding SearchCommand}" />
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="SearchRow" Height="310" MinHeight="310"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Search Criteria" Margin="10">
            <views:SearchView DataContext="{Binding SearchVm}" Margin="0,5,0,0"/>
        </GroupBox>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" ResizeBehavior="PreviousAndNext"/>

        <views:ResultsView Grid.Row="2" DataContext="{Binding ResultsVm}" Margin="10,0,10,10"/>

        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Julian:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding JulianDateText, UpdateSourceTrigger=PropertyChanged}" Width="60" MaxLength="7" VerticalContentAlignment="Center"/>
                    <TextBlock Text="Gregorian:" Margin="10,0,5,0" VerticalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding GregorianDate}" Width="100"/>
                    <TextBlock Text="Database:" Margin="10,0,5,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="DatabaseComboBox" Width="150" Height="22" VerticalAlignment="Center"
                              ItemsSource="{Binding DatabasesView}" SelectedItem="{Binding SelectedDatabase}"
                              IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                              VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                              PreviewKeyDown="DatabaseComboBox_PreviewKeyDown" KeyUp="DatabaseComboBox_KeyUp" GotFocus="DatabaseComboBox_GotFocus">
                    </ComboBox>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource TransparentIconButtonStyle}" ToolTip="Settings" Margin="0,0,10,0">
                        <Control Template="{StaticResource Icon_Settings}"
                               Width="16" Height="16"/>
                    </Button>
                    <ToggleButton Command="{Binding OpenUnarchiveCommand}" IsChecked="{Binding IsUnarchiveTargetVisible, Mode=OneWay}" ToolTip="Unarchive Target"
                                  Background="Transparent" BorderThickness="0" Padding="0">
                        <ToggleButton.Style>
                             <Style TargetType="ToggleButton">
                                 <Setter Property="Template">
                                     <Setter.Value>
                                         <ControlTemplate TargetType="ToggleButton">
                                             <Border Background="Transparent">
                                                 <ContentPresenter/>
                                             </Border>
                                         </ControlTemplate>
                                     </Setter.Value>
                                 </Setter>
                             </Style>
                        </ToggleButton.Style>
                        <Image Source="/Resources/Unarchive.png" Width="16" Height="16"/>
                    </ToggleButton>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid x:Name="MaskOverlay" Background="#AA000000" Visibility="Collapsed" Grid.RowSpan="4"/>
    </Grid>
</Window>
